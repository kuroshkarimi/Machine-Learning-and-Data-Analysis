      "cell_type": "code",
      "source": [
        "# __ Splitting the data into train and test sections\n",
        "\n",
        "from sklearn.model_selection import train_test_split\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.25, random_state=0)"
      ],
      "outputs": [],
      "execution_count": null
    },
    {
      "metadata": {
        "ExecuteTime": {
          "end_time": "2025-08-05T09:03:10.605432Z",
          "start_time": "2025-08-05T09:03:10.592058Z"
        },
        "id": "-6MiJRPHn2jP",
        "outputId": "517369ae-7d59-4df7-dd97-cee78882ec35"
      },
      "cell_type": "code",
      "source": [
        "# __ fitting the data with multiple linear regressive model and its r2 parameter\n",
        "from sklearn.pipeline import Pipeline\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.linear_model import LinearRegression\n",
        "from sklearn.metrics import r2_score, root_mean_squared_error, mean_absolute_error\n",
        "\n",
        "# creation of the pipeline object with standard scaler normalization and multiple linear regression estimator\n",
        "pipe_lin = Pipeline(steps=[('scaler', StandardScaler()), ('model', LinearRegression())])\n",
        "pipe_lin.fit(X_train, y_train)\n",
        "y_lin = pipe_lin.predict(X_test)\n",
        "r2_lin = pipe_lin.score(X_test, y_test)\n",
        "rmse_lin = -root_mean_squared_error(y_test, y_lin)\n",
        "mae_lin = -mean_absolute_error(y_test, y_lin)\n",
        "print(f'Multiple Linear Regression R-Squared = {r2_lin:.3f}')\n",
        "print(f'negative Multiple Linear Regression RMSE = {rmse_lin:.3f}')\n",
        "print(f'negative Multiple Linear Regression MAE = {mae_lin:.3f}')"
      ],
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Multiple Linear Regression R-Squared = 0.932\n",
            "negative Multiple Linear Regression RMSE = -4.453\n",
            "negative Multiple Linear Regression MAE = -3.561\n"
          ]
        }
      ],
      "execution_count": null
    },
    {
      "metadata": {
        "ExecuteTime": {
